# Traefik & Domain Configuration
# Copy this file to .env and update with your values

# Email for Let's Encrypt SSL certificates (REQUIRED for production)
EMAIL=your-email@example.com

# Traefik Log level: DEBUG, INFO, WARN, ERROR
TRAEFIK_LOG_LEVEL=INFO

# Base Domain name (e.g. sahajanand.digital, or localhost for local development)
BASE_DOMAIN=localhost

# Infrastructure Domains (Configures Traefik Routing Hosts)
WEBUI_HOST=webui.${BASE_DOMAIN}
PHPMYADMIN_HOST=phpmyadmin.${BASE_DOMAIN}
PHPLITEADMIN_HOST=phpliteadmin.${BASE_DOMAIN}

# Container Restart Policy (e.g., unless-stopped, always, no)
RESTART_POLICY=unless-stopped

# Advanced Traefik Configuration
# Options: traefik.prod.yml (production with SSL) or traefik.yml (local development)
TRAEFIK_CONFIG_FILE=traefik.prod.yml
# Dashboard Bind: 127.0.0.1:8080 (localhost secure) or 8080 (publicly exposed)
TRAEFIK_DASHBOARD_BIND=127.0.0.1:8080

# Web UI HTTP Middleware (set to redirect-to-https@file in production, or gzip@file in dev)
WEBUI_HTTP_MIDDLEWARE=redirect-to-https@file

# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_PORT=3306

# Rclone Backup Configuration
# Set the rclone remote name and path. E.g., gdrive:Backups/sahajanand-server
RCLONE_REMOTE_PATH=

# Optional: Path to a custom rclone config file
# RCLONE_CONFIG_PATH=/var/www/project/rclone.conf

# Google Drive Service Account configuration (Highly recommended for headless VPS backups)
# To configure Google Drive automatically, uncomment the variables below and place 
# your service account json file as 'rclone-gdrive-sa.json' in the project root.
# RCLONE_CONFIG_GDRIVE_TYPE=drive
# RCLONE_CONFIG_GDRIVE_SCOPE=drive
# RCLONE_CONFIG_GDRIVE_SERVICE_ACCOUNT_FILE=/var/www/project/rclone-gdrive-sa.json

